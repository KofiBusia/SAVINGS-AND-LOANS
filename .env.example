# =============================================================================
# Ghana Savings & Loan Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
#
# For production, use a secrets manager:
#   - GCP Secret Manager (recommended for GCP deployments)
#   - AWS Secrets Manager (for AWS deployments)
#   - HashiCorp Vault (cloud-agnostic)
#
# Ghana regulatory note:
#   All credentials for NIA, GhIPSS, FIC systems are issued by
#   the respective government agencies and must be stored securely.
# =============================================================================

# =============================================================================
# Application
# =============================================================================

# Environment: development | staging | production
NODE_ENV=development

# Application version (auto-set by CI/CD; override manually for local dev)
APP_VERSION=0.0.0-dev

# Ghana regulatory: operator licence number issued by BoG
# Format: MFI/TIER2/XXXX/YYYY (Tier 2 MFI) or MFI/TIER3/XXXX/YYYY (Tier 3)
BOG_LICENCE_NUMBER=MFI/TIER2/0001/2025

# Institution name as registered with BoG (must match licence exactly)
INSTITUTION_NAME=Your Savings and Loans Company Limited

# =============================================================================
# Database — PostgreSQL
# =============================================================================

# Primary database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghana_savings_loan
DB_USER=gsl_app
# Minimum 32 characters; use: openssl rand -hex 32
DB_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# Read replica (for reporting queries, BoG returns — do not use primary)
DB_REPLICA_HOST=localhost
DB_REPLICA_PORT=5433

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# SSL for production (set to 'true' in staging/production)
DB_SSL=false
# Path to CA certificate for SSL verification
DB_SSL_CA_PATH=

# =============================================================================
# Redis — Cache, Sessions, Job Queues
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
# Minimum 32 characters
REDIS_PASSWORD=CHANGE_ME_redis_password

# Redis databases (0-15) — separate logical databases per service
REDIS_DB_SESSIONS=0
REDIS_DB_CACHE=1
REDIS_DB_JOBS=2
REDIS_DB_RATE_LIMIT=3

# Session TTL
REDIS_SESSION_TTL_SECONDS=900

# =============================================================================
# Encryption & Security
# =============================================================================

# AES-256 master encryption key for PII fields in database
# CRITICAL: Must be 64 hex characters (32 bytes = 256 bits)
# Generate: openssl rand -hex 32
# In production: NEVER set here — use GCP KMS / AWS KMS
ENCRYPTION_MASTER_KEY=CHANGE_ME_64_hex_chars_aes256_key_here_never_use_in_production

# JWT signing (RS256 — use key pairs; these are private key paths)
# In production: keys stored in GCP Secret Manager / AWS Secrets Manager
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Session secret (min 32 chars)
SESSION_SECRET=CHANGE_ME_min_32_chars_session_secret

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# NIA (National Identification Authority) — Ghana Card Verification
# =============================================================================
# API credentials issued by NIA Ghana upon signing Integration Agreement
# Apply at: https://nia.gov.gh/developers
#
# Ghana regulatory note: NIA integration is MANDATORY for customer onboarding
# under the BoG KYC Requirements 2021 and AML/CFT Guidelines 2021.

NIA_API_URL=https://api.nia.gov.gh/v1
NIA_API_KEY=CHANGE_ME_obtain_from_NIA_Ghana
NIA_API_SECRET=CHANGE_ME_obtain_from_NIA_Ghana

# NIA webhook secret (for verifying NIA-pushed verification results)
NIA_WEBHOOK_SECRET=CHANGE_ME_nia_webhook_hmac_secret

# Timeout for NIA API calls (ms) — NIA SLA is 3 seconds
NIA_API_TIMEOUT_MS=5000

# Cache successful NIA verifications (Ghana Card checked valid) for this duration
# Note: Under NIA Integration Guide 2024, cached verifications valid for 24 hours
NIA_CACHE_TTL_SECONDS=86400

# =============================================================================
# GhIPSS — Ghana Interbank Payment and Settlement System
# =============================================================================
# Credentials issued by GhIPSS upon execution of Participant Agreement
# Contact: participation@ghipss.net
#
# Ghana regulatory note: GhIPSS settlement is final and irrevocable
# per Payment Systems and Services Act 2019.

GHIPSS_API_URL=https://api.ghipss.net/v3
GHIPSS_PARTICIPANT_CODE=CHANGE_ME_ghipss_participant_code
GHIPSS_API_KEY=CHANGE_ME_ghipss_api_key
GHIPSS_API_SECRET=CHANGE_ME_ghipss_api_secret

# GhIPSS institution code (4-digit code assigned by GhIPSS)
GHIPSS_INSTITUTION_CODE=0000

# Signing certificate for GhIPSS messages (mTLS)
GHIPSS_CLIENT_CERT_PATH=./certs/ghipss-client.crt
GHIPSS_CLIENT_KEY_PATH=./certs/ghipss-client.key
GHIPSS_CA_CERT_PATH=./certs/ghipss-ca.crt

# =============================================================================
# Mobile Money — MTN MoMo
# =============================================================================
# MTN MoMo API credentials from MoMo Developer Portal
# Apply at: https://momodeveloper.mtn.com
#
# Ghana note: MTN is the largest MNO in Ghana (prefix 024, 054, 055, 059)

MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=CHANGE_ME_mtn_momo_subscription_key
MTN_MOMO_API_USER=CHANGE_ME_uuid_format
MTN_MOMO_API_KEY=CHANGE_ME_mtn_momo_api_key
MTN_MOMO_ENVIRONMENT=sandbox
# MTN MoMo callback URL (must be HTTPS in production)
MTN_MOMO_CALLBACK_URL=https://your-domain.com.gh/api/v1/payments/callbacks/mtn

# =============================================================================
# Mobile Money — Telecel Cash (formerly Vodafone Cash)
# =============================================================================
# Telecel Ghana developer credentials
# Ghana note: Telecel prefixes: 020, 050

TELECEL_API_URL=https://api.telecel.com.gh/v1
TELECEL_API_KEY=CHANGE_ME_telecel_api_key
TELECEL_MERCHANT_ID=CHANGE_ME_telecel_merchant_id
TELECEL_CALLBACK_URL=https://your-domain.com.gh/api/v1/payments/callbacks/telecel

# =============================================================================
# Mobile Money — AirtelTigo Money
# =============================================================================
# AirtelTigo developer credentials
# Ghana note: AirtelTigo prefixes: 026, 056, 027, 057

AIRTELTIGO_API_URL=https://api.airteltigo.com.gh/v1
AIRTELTIGO_API_KEY=CHANGE_ME_airteltigo_api_key
AIRTELTIGO_MERCHANT_ID=CHANGE_ME_airteltigo_merchant_id
AIRTELTIGO_CALLBACK_URL=https://your-domain.com.gh/api/v1/payments/callbacks/airteltigo

# =============================================================================
# Credit Bureau — CRB Africa
# =============================================================================
# CRB Africa Ghana credentials for credit checks
# Contact: ghana@crbafrica.com
#
# Ghana regulatory note: Credit checks are required under BoG DCD 2025 §6
# for loans above GHS 500. Results must be retained for 7 years.

BUREAU_API_URL=https://api.gh.crbafrica.com/v2
BUREAU_API_KEY=CHANGE_ME_crb_africa_api_key
BUREAU_API_SECRET=CHANGE_ME_crb_africa_secret

# =============================================================================
# Notifications — Hubtel SMS (primary Ghana SMS gateway)
# =============================================================================
# Hubtel is the leading SMS gateway in Ghana
# Apply at: https://developers.hubtel.com
#
# Ghana note: All SMS to customers must include opt-out instructions
# per DPA 2012 consent requirements.

HUBTEL_CLIENT_ID=CHANGE_ME_hubtel_client_id
HUBTEL_CLIENT_SECRET=CHANGE_ME_hubtel_client_secret
HUBTEL_SENDER_ID=YourBrand
# Hubtel short code for 2-way SMS (optional, for USSD integration)
HUBTEL_SHORT_CODE=

# =============================================================================
# Email (SMTP)
# =============================================================================

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.com.gh
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM_NAME=Your Savings & Loans
SMTP_FROM_ADDRESS=noreply@your-domain.com.gh

# =============================================================================
# Push Notifications (Firebase Cloud Messaging)
# =============================================================================

FCM_SERVER_KEY=CHANGE_ME_firebase_server_key
FCM_PROJECT_ID=your-firebase-project

# =============================================================================
# Storage — Document storage for KYC files, loan agreements
# =============================================================================

# Storage provider: gcs | s3 | local (local for dev only)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# GCS configuration (when STORAGE_PROVIDER=gcs)
# Ghana data localization: use region africa-south1
GCS_BUCKET_NAME=your-project-kyc-documents
GCS_PROJECT_ID=your-gcp-project
GCS_REGION=africa-south1
# Path to GCP service account key (in production, use Workload Identity instead)
GCS_KEY_PATH=./gcp-service-account.json

# AWS S3 configuration (when STORAGE_PROVIDER=s3)
# Ghana data localization: use region af-south-1 (Cape Town, nearest to Ghana)
AWS_S3_BUCKET=your-kyc-documents-bucket
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# =============================================================================
# Observability
# =============================================================================

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Tracing (OpenTelemetry)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ghana-savings-loan
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Sentry (error tracking)
SENTRY_DSN=CHANGE_ME_sentry_dsn
SENTRY_ENVIRONMENT=development

# =============================================================================
# Monitoring (local dev)
# =============================================================================

GRAFANA_PORT=3030
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

MAILHOG_WEB_PORT=8025

# =============================================================================
# Ports (local dev overrides)
# =============================================================================

FRONT_OFFICE_PORT=3000
BACK_OFFICE_PORT=3001
API_GATEWAY_PORT=8080

# =============================================================================
# Service URLs (for inter-service communication)
# =============================================================================

LOAN_SERVICE_URL=http://loan-service:3010
SAVINGS_SERVICE_URL=http://savings-service:3011
KYC_SERVICE_URL=http://kyc-service:3012
PAYMENT_SERVICE_URL=http://payment-service:3013
NOTIFICATION_SERVICE_URL=http://notification-service:3014
COMPLIANCE_SERVICE_URL=http://compliance-service:3015

# =============================================================================
# Regulatory Parameters
# =============================================================================
# These match constants in shared/src/constants/compliance.ts
# Do NOT change without legal/regulatory review.

# BoG DCD 2025: Maximum annual lending rate (%)
# Current BoG policy rate + spread ceiling
BOG_MAX_LENDING_RATE_APR=50

# FIC Act 2020: Cash Transaction Report threshold (GHS)
FIC_CTR_THRESHOLD_GHS=10000

# BoG Consumer Protection 2019: Max complaint resolution (working days)
BOG_COMPLAINT_RESOLUTION_WORKING_DAYS=20

# FIC Act 2020: Record retention period (years)
FIC_RECORD_RETENTION_YEARS=7

# =============================================================================
# Feature Flags
# =============================================================================

# Enable offline mode for mobile app
FEATURE_OFFLINE_MODE=true

# Enable biometric authentication
FEATURE_BIOMETRIC_AUTH=true

# Enable USSD fallback
FEATURE_USSD=false

# Enable automatic STR filing (vs manual review queue)
FEATURE_AUTO_STR_FILING=false

# Enable credit bureau integration
FEATURE_CREDIT_BUREAU=true
