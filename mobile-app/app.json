{
  "expo": {
    "name": "Ghana Savings & Loans",
    "slug": "ghana-savings-loans",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.savingsloans.ghana",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for Ghana Card scanning and liveness verification",
        "NSFaceIDUsageDescription": "Used for biometric authentication",
        "NSLocationWhenInUseUsageDescription": "Used for address verification and field operations"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.savingsloans.ghana",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication",
      "expo-location",
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "ghana-savings-loans-project-id"
      }
    }
  }
}
